{
	"name": "php-wasm-web",
	"$schema": "../../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "packages/php-wasm/web/src",
	"projectType": "library",
	"tags": ["scope:php-binaries"],
	"implicitDependencies": ["php-wasm-compile"],
	"targets": {
		"build": {
			"executor": "nx:noop",
			"dependsOn": ["build:README"]
		},
		"build:README": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"cp packages/php-wasm/web/README.md dist/packages/php-wasm/web"
				]
			},
			"dependsOn": ["build:copy-shared"]
		},
		"build:copy-shared": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"mkdir -p dist/packages/php-wasm/web/shared",
					"cp -rf packages/php-wasm/web/src/lib/extensions/intl/shared/* dist/packages/php-wasm/web/shared/"
				],
				"parallel": false
			},
			"dependsOn": ["build:package-json"]
		},
		"build:package-json": {
			"executor": "@wp-playground/nx-extensions:package-json",
			"options": {
				"tsConfig": "packages/php-wasm/web/tsconfig.lib.json",
				"outputPath": "dist/packages/php-wasm/web",
				"buildTarget": "php-wasm-web:build:bundle"
			}
		},
		"build:bundle": {
			"executor": "@nx/vite:build",
			"outputs": ["{options.outputPath}"],
			"options": {
				"emptyOutDir": false,
				"outputPath": "dist/packages/php-wasm/web"
			}
		},
		"build:playwright": {
			"executor": "@nx/vite:build",
			"outputs": ["{options.outputPath}"],
			"options": {
				"configFile": "packages/php-wasm/web/vite.playwright.config.ts"
			}
		},
		"dev": {
			"executor": "@nx/vite:dev-server",
			"options": {
				"buildTarget": "php-wasm-web:build:playwright"
			}
		},
		"recompile-php:all": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"nx run php-wasm-web:recompile-php:jspi:all",
					"nx run php-wasm-web:recompile-php:asyncify:all"
				],
				"parallel": false
			}
		},
		"recompile-php:jspi": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"node packages/php-wasm/compile/build.js --PLATFORM=web --WITH_JSPI=yes"
				],
				"parallel": false
			}
		},
		"recompile-php:jspi:all": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"node packages/php-wasm/compile/build.js --PLATFORM=web --PHP_VERSION=8.5 --WITH_JSPI=yes",
					"node packages/php-wasm/compile/build.js --PLATFORM=web --PHP_VERSION=8.4 --WITH_JSPI=yes",
					"node packages/php-wasm/compile/build.js --PLATFORM=web --PHP_VERSION=8.3 --WITH_JSPI=yes",
					"node packages/php-wasm/compile/build.js --PLATFORM=web --PHP_VERSION=8.2 --WITH_JSPI=yes",
					"node packages/php-wasm/compile/build.js --PLATFORM=web --PHP_VERSION=8.1 --WITH_JSPI=yes",
					"node packages/php-wasm/compile/build.js --PLATFORM=web --PHP_VERSION=8.0 --WITH_JSPI=yes",
					"node packages/php-wasm/compile/build.js --PLATFORM=web --PHP_VERSION=7.4 --WITH_JSPI=yes"
				],
				"parallel": false
			}
		},
		"recompile-php:asyncify": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"node packages/php-wasm/compile/build.js --PLATFORM=web"
				],
				"parallel": false
			}
		},
		"recompile-php:asyncify:all": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"node packages/php-wasm/compile/build.js --PLATFORM=web --PHP_VERSION=8.5",
					"node packages/php-wasm/compile/build.js --PLATFORM=web --PHP_VERSION=8.4",
					"node packages/php-wasm/compile/build.js --PLATFORM=web --PHP_VERSION=8.3",
					"node packages/php-wasm/compile/build.js --PLATFORM=web --PHP_VERSION=8.2",
					"node packages/php-wasm/compile/build.js --PLATFORM=web --PHP_VERSION=8.1",
					"node packages/php-wasm/compile/build.js --PLATFORM=web --PHP_VERSION=8.0",
					"node packages/php-wasm/compile/build.js --PLATFORM=web --PHP_VERSION=7.4"
				],
				"parallel": false
			}
		},
		"publish": {
			"executor": "nx:run-commands",
			"options": {
				"command": "node tools/scripts/publish.mjs php-wasm {args.ver} {args.tag}",
				"parallel": false
			},
			"dependsOn": ["build"]
		},
		"package-for-self-hosting": {
			"executor": "@wp-playground/nx-extensions:package-for-self-hosting",
			"dependsOn": ["build"]
		},
		"test": {
			"executor": "@nx/vitest:test",
			"outputs": ["{workspaceRoot}/coverage/packages/php-wasm/web"],
			"options": {
				"reportsDirectory": "../../coverage/packages/php-wasm/web",
				"testFiles": [
					"prf.spec.ts",
					"certificates.spec.ts",
					"tcp-over-fetch-websocket.spec.ts"
				]
			}
		},
		"e2e": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"npx playwright test --config=packages/php-wasm/web/playwright.config.ts"
				]
			}
		},
		"lint": {
			"executor": "@nx/eslint:lint",
			"outputs": ["{options.outputFile}"],
			"options": {
				"useFlatConfig": false,
				"lintFilePatterns": ["packages/php-wasm/web/**/*.ts"],
				"maxWarnings": 0
			}
		},
		"typecheck": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"tsc -p packages/php-wasm/web/tsconfig.lib.json --noEmit",
					"tsc -p packages/php-wasm/web/tsconfig.spec.json --noEmit"
				]
			}
		}
	}
}
