{
	"name": "php-wasm-node",
	"$schema": "../../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "packages/php-wasm/node/src",
	"projectType": "library",
	"tags": ["scope:php-binaries"],
	"implicitDependencies": ["php-wasm-compile"],
	"targets": {
		"build": {
			"executor": "nx:noop",
			"dependsOn": ["build:README", "build:dts"]
		},
		"build:README": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"cp packages/php-wasm/node/README.md dist/packages/php-wasm/node"
				]
			},
			"dependsOn": ["build:package-json"]
		},
		"build:package-json": {
			"executor": "@wp-playground/nx-extensions:package-json",
			"options": {
				"tsConfig": "packages/php-wasm/node/tsconfig.lib.json",
				"outputPath": "dist/packages/php-wasm/node",
				"buildTarget": "php-wasm-node:build:bundle:production"
			},
			"dependsOn": ["build:mkdir"]
		},
		"build:dts": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "packages/php-wasm/node",
				"commands": [
					"npx -p typescript tsc --project tsconfig.lib.json --declaration --allowJs --emitDeclarationOnly --outDir ../../../dist/packages/php-wasm/out-tsc-phpwasm-node",
					"cp -r ../../../dist/packages/php-wasm/out-tsc-phpwasm-node/packages/php-wasm/node/src/* ../../../dist/packages/php-wasm/node"
				],
				"parallel": false
			},
			"dependsOn": ["build:copy-shared"]
		},
		"build:copy-shared": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"mkdir -p dist/packages/php-wasm/node/shared",
					"cp -rf packages/php-wasm/node/src/lib/extensions/intl/shared/* dist/packages/php-wasm/node/shared/"
				],
				"parallel": false
			},
			"dependsOn": ["build:bundle"]
		},
		"build:bundle": {
			"executor": "nx:run-commands",
			"options": {
				"command": "node packages/php-wasm/node/build.js",
				"parallel": false
			},
			"dependsOn": ["build:mkdir"]
		},
		"build:mkdir": {
			"executor": "nx:run-commands",
			"options": {
				"commands": ["mkdir -p dist/packages/php-wasm/node"],
				"parallel": false
			}
		},
		"recompile-php:all": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"nx run php-wasm-node:recompile-php:jspi:all",
					"nx run php-wasm-node:recompile-php:asyncify:all"
				],
				"parallel": false
			}
		},
		"recompile-php:jspi": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"node packages/php-wasm/compile/build.js --PLATFORM=node --WITH_JSPI=yes"
				],
				"parallel": false
			}
		},
		"recompile-php:jspi:all": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"node packages/php-wasm/compile/build.js --PLATFORM=node --PHP_VERSION=8.5 --WITH_JSPI=yes",
					"node packages/php-wasm/compile/build.js --PLATFORM=node --PHP_VERSION=8.4 --WITH_JSPI=yes",
					"node packages/php-wasm/compile/build.js --PLATFORM=node --PHP_VERSION=8.3 --WITH_JSPI=yes",
					"node packages/php-wasm/compile/build.js --PLATFORM=node --PHP_VERSION=8.2 --WITH_JSPI=yes",
					"node packages/php-wasm/compile/build.js --PLATFORM=node --PHP_VERSION=8.1 --WITH_JSPI=yes",
					"node packages/php-wasm/compile/build.js --PLATFORM=node --PHP_VERSION=8.0 --WITH_JSPI=yes",
					"node packages/php-wasm/compile/build.js --PLATFORM=node --PHP_VERSION=7.4 --WITH_JSPI=yes"
				],
				"parallel": false
			}
		},
		"recompile-php:asyncify": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"node packages/php-wasm/compile/build.js --PLATFORM=node"
				],
				"parallel": false
			}
		},
		"recompile-php:asyncify:all": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"node packages/php-wasm/compile/build.js --PLATFORM=node --PHP_VERSION=8.5",
					"node packages/php-wasm/compile/build.js --PLATFORM=node --PHP_VERSION=8.4",
					"node packages/php-wasm/compile/build.js --PLATFORM=node --PHP_VERSION=8.3",
					"node packages/php-wasm/compile/build.js --PLATFORM=node --PHP_VERSION=8.2",
					"node packages/php-wasm/compile/build.js --PLATFORM=node --PHP_VERSION=8.1",
					"node packages/php-wasm/compile/build.js --PLATFORM=node --PHP_VERSION=8.0",
					"node packages/php-wasm/compile/build.js --PLATFORM=node --PHP_VERSION=7.4"
				],
				"parallel": false
			}
		},
		"package-json": {
			"executor": "@wp-playground/nx-extensions:package-json",
			"options": {
				"tsConfig": "packages/php-wasm/node/tsconfig.lib.json",
				"outputPath": "dist/packages/php-wasm/node",
				"buildTarget": "php-wasm-node:build:production"
			}
		},
		"publish": {
			"executor": "nx:run-commands",
			"options": {
				"command": "node tools/scripts/publish.mjs php-wasm-node {args.ver} {args.tag}",
				"parallel": false
			},
			"dependsOn": ["build"]
		},
		"package-for-self-hosting": {
			"executor": "@wp-playground/nx-extensions:package-for-self-hosting",
			"dependsOn": ["build"]
		},
		"test-group-1-asyncify": {
			"executor": "@nx/vitest:test",
			"outputs": ["{workspaceRoot}/coverage/packages/php-wasm/node"],
			"options": {
				"reportsDirectory": "../../../coverage/packages/php-wasm/node",
				"testFiles": ["php-part-1.spec.ts"]
			}
		},
		"test-group-1-jspi": {
			"executor": "@nx/vitest:test",
			"outputs": ["{workspaceRoot}/coverage/packages/php-wasm/node"],
			"options": {
				"configFile": "packages/php-wasm/node/vite.jspi.config.ts",
				"reportsDirectory": "../../../coverage/packages/php-wasm/node",
				"testFiles": ["php-part-1.spec.ts"]
			}
		},
		"test-group-2-asyncify": {
			"executor": "@nx/vitest:test",
			"outputs": ["{workspaceRoot}/coverage/packages/php-wasm/node"],
			"options": {
				"reportsDirectory": "../../../coverage/packages/php-wasm/node",
				"testFiles": [
					"php-imagick.spec.ts",
					"php-soap.spec.ts",
					"php-image-extensions.spec.ts",
					"php-fsockopen.spec.ts"
