				"reportsDirectory": "../../../coverage/packages/php-wasm/node",
				"testFiles": ["php-memcached.spec.ts"],
				"testNamePattern": "Memcached Network Integration"
			}
		},
		"test-file-locking-asyncify": {
			"executor": "@nx/vite:test",
			"outputs": ["{workspaceRoot}/coverage/packages/php-wasm/node"],
			"options": {
				"reportsDirectory": "../../../coverage/packages/php-wasm/node",
				"testFiles": [
					"php-file-locking.spec.ts",
					"file-lock-manager-in-memory.spec.ts",
					"file-lock-manager-for-posix.spec.ts",
					"file-lock-manager-for-windows.spec.ts",
