		},
		"test-group-2-jspi": {
			"executor": "@nx/vitest:test",
			"outputs": ["{workspaceRoot}/coverage/packages/php-wasm/node"],
			"options": {
				"configFile": "packages/php-wasm/node/vite.jspi.config.ts",
				"reportsDirectory": "../../../coverage/packages/php-wasm/node",
				"testFiles": [
					"php-imagick.spec.ts",
					"php-soap.spec.ts",
					"php-image-extensions.spec.ts",
					"php-fsockopen.spec.ts"
				]
			}
		},
		"test-group-3-asyncify": {
			"executor": "@nx/vitest:test",
			"outputs": ["{workspaceRoot}/coverage/packages/php-wasm/node"],
			"options": {
				"reportsDirectory": "../../../coverage/packages/php-wasm/node",
				"testFiles": [
					"php-request-handler.spec.ts",
					"mount.spec.ts",
					"rotate-php-runtime.spec.ts",
					"php-fopen.spec.ts",
					"php-file-get-contents.spec.ts",
					"php-gethostbyname.spec.ts"
				]
			}
		},
		"test-group-3-jspi": {
			"executor": "@nx/vitest:test",
			"outputs": ["{workspaceRoot}/coverage/packages/php-wasm/node"],
			"options": {
				"configFile": "packages/php-wasm/node/vite.jspi.config.ts",
				"reportsDirectory": "../../../coverage/packages/php-wasm/node",
				"testFiles": [
					"php-request-handler.spec.ts",
					"mount.spec.ts",
					"rotate-php-runtime.spec.ts",
					"php-fopen.spec.ts",
					"php-file-get-contents.spec.ts",
					"php-gethostbyname.spec.ts"
				]
			}
		},
		"test-group-4-asyncify": {
			"executor": "@nx/vitest:test",
			"outputs": ["{workspaceRoot}/coverage/packages/php-wasm/node"],
			"options": {
				"reportsDirectory": "../../../coverage/packages/php-wasm/node",
				"testFiles": [
					"symlinks.spec.ts",
					"php-sqlite3.spec.ts",
					"php-networking.spec.ts",
					"php-dynamic-loading.spec.ts",
					"php-mysqli.spec.ts",
					"php-process-manager.spec.ts",
					"proxyfs-mmap.spec.ts"
				]
			}
		},
		"test-group-4-jspi": {
			"executor": "@nx/vitest:test",
			"outputs": ["{workspaceRoot}/coverage/packages/php-wasm/node"],
			"options": {
				"configFile": "packages/php-wasm/node/vite.jspi.config.ts",
				"reportsDirectory": "../../../coverage/packages/php-wasm/node",
				"testFiles": [
					"symlinks.spec.ts",
					"php-sqlite3.spec.ts",
					"php-networking.spec.ts",
					"php-dynamic-loading.spec.ts",
					"php-mysqli.spec.ts",
					"php-process-manager.spec.ts",
					"proxyfs-mmap.spec.ts"
				]
			}
		},
		"test-group-5-asyncify": {
			"executor": "@nx/vitest:test",
			"outputs": ["{workspaceRoot}/coverage/packages/php-wasm/node"],
			"options": {
				"reportsDirectory": "../../../coverage/packages/php-wasm/node",
				"testFiles": [
					"php-crash.spec.ts",
					"php-ini.spec.ts",
					"write-files.spec.ts",
					"php-worker.spec.ts",
					"unzip-file.spec.ts",
					"php-vars.spec.ts",
					"php-memory.spec.ts",
					"php-opcache.spec.ts"
				]
			}
		},
		"test-group-5-jspi": {
			"executor": "@nx/vitest:test",
			"outputs": ["{workspaceRoot}/coverage/packages/php-wasm/node"],
			"options": {
				"configFile": "packages/php-wasm/node/vite.jspi.config.ts",
				"reportsDirectory": "../../../coverage/packages/php-wasm/node",
				"testFiles": [
					"php-crash.spec.ts",
					"php-ini.spec.ts",
					"write-files.spec.ts",
					"php-worker.spec.ts",
					"unzip-file.spec.ts",
					"php-vars.spec.ts",
					"php-memory.spec.ts"
				]
			}
		},
		"test-group-6-asyncify": {
			"executor": "@nx/vitest:test",
			"outputs": ["{workspaceRoot}/coverage/packages/php-wasm/node"],
			"options": {
				"reportsDirectory": "../../../coverage/packages/php-wasm/node",
				"testFiles": ["php-part-2.spec.ts"]
			}
		},
		"test-group-6-jspi": {
			"executor": "@nx/vitest:test",
			"outputs": ["{workspaceRoot}/coverage/packages/php-wasm/node"],
			"options": {
				"configFile": "packages/php-wasm/node/vite.jspi.config.ts",
				"reportsDirectory": "../../../coverage/packages/php-wasm/node",
				"testFiles": ["php-part-2.spec.ts"]
			}
		},
		"test-redis-extension-jspi": {
			"executor": "@nx/vitest:test",
			"outputs": ["{workspaceRoot}/coverage/packages/php-wasm/node"],
			"options": {
				"configFile": "packages/php-wasm/node/vite.jspi.config.ts",
				"reportsDirectory": "../../../coverage/packages/php-wasm/node",
				"testFiles": ["php-redis.spec.ts"],
				"testNamePattern": "Redis Extension"
			}
		},
		"test-redis-network-jspi": {
			"executor": "@nx/vitest:test",
			"outputs": ["{workspaceRoot}/coverage/packages/php-wasm/node"],
			"options": {
				"configFile": "packages/php-wasm/node/vite.jspi.config.ts",
				"reportsDirectory": "../../../coverage/packages/php-wasm/node",
				"testFiles": ["php-redis.spec.ts"],
				"testNamePattern": "Redis Network Integration"
			}
		},
		"test-memcached-extension-jspi": {
			"executor": "@nx/vitest:test",
			"outputs": ["{workspaceRoot}/coverage/packages/php-wasm/node"],
			"options": {
				"configFile": "packages/php-wasm/node/vite.jspi.config.ts",
				"reportsDirectory": "../../../coverage/packages/php-wasm/node",
				"testFiles": ["php-memcached.spec.ts"],
				"testNamePattern": "Memcached Extension"
			}
		},
		"test-memcached-network-jspi": {
			"executor": "@nx/vitest:test",
