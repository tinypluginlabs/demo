Options +Multiviews
AddEncoding x-gzip .gz

# Rewrite blueprint preset routes to index.html with local blueprint-url parameter
RewriteEngine On
RewriteRule ^tinyrelated$ /index.html?blueprint-url=/blueprints/tinyrelated.zip [QSA,L]
RewriteRule ^tinyratings$ /index.html?blueprint-url=/blueprints/tinyratings.zip [QSA,L]

<FilesMatch "index\.html">
Header unset ETag
Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
</FilesMatch>
<FilesMatch "index\.js|blueprint-schema\.json|logger.php|wp-cli.phar|wordpress-importer.zip">
Header set Access-Control-Allow-Origin "*"
Header unset ETag
Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
</FilesMatch>