Options +Multiviews
AddEncoding x-gzip .gz

# Rewrite /tinyrelated to index.html with blueprint-url parameter
RewriteEngine On
RewriteRule ^tinyrelated$ /index.html?blueprint-url=https://github.com/tinypluginlabs/tmp/releases/download/playground-preview-pr-89/blueprint.json [QSA,L]

<FilesMatch "index\.html">
Header unset ETag
Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
</FilesMatch>
<FilesMatch "index\.js|blueprint-schema\.json|logger.php|wp-cli.phar|wordpress-importer.zip">
Header set Access-Control-Allow-Origin "*"
Header unset ETag
Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
</FilesMatch>