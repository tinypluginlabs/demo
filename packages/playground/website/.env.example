# Google Analytics 4 measurement ID.
# When set, the gtag snippet is injected into HTML files at build time.
# When absent, no analytics code is shipped.
# Format: G-XXXXXXXXXX
# VITE_GOOGLE_ANALYTICS_ID=

# Feature flags - when set to 'no', completely disables features at build time
# Users cannot re-enable via query parameters
# VITE_CAN_SAVE=no
# VITE_CAN_INSTALL=no
# VITE_CAN_EDIT=no
